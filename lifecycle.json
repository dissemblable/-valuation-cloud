{
  "rules": [
    {
      "enabled": true,
      "name": "delete-old-attachments",
      "type": "Lifecycle",
      "definition": {
        "actions": {
          "baseBlob": {
            "delete": { "daysAfterModificationGreaterThan": 30 }
          }
        },
        "filters": {
          "blobTypes": ["blockBlob"],
          "prefixMatch": ["todo-attachments/"]
        }
      }
    }
  ]
}
