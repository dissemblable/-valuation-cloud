# .env.example — copie ce fichier en .env et remplis les valeurs pour le dev local
# En production sur Azure App Service, ces valeurs seront définies dans les
# "Application Settings" et le secret sensible (COSMOS_KEY) sera lu depuis Key Vault.

# === Cosmos DB ===
COSMOS_ENDPOINT=https://<ton-compte-cosmos>.documents.azure.com:443/
COSMOS_KEY=<ta-cle-primaire-cosmos>
COSMOS_DATABASE=todoapp
COSMOS_CONTAINER=todos

# === Blob Storage ===
# En local on utilise la connection string (plus simple).
# En prod, on utilise STORAGE_ACCOUNT_NAME + Managed Identity.
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
BLOB_CONTAINER_NAME=todo-attachments

# === Key Vault (laisse vide en local pour utiliser les variables ci-dessus) ===
# KEY_VAULT_NAME=mon-keyvault

# === App ===
PORT=3000
